# AI Forecasting API Environment Configuration

# API Settings
API_V1_STR=/api/v1
PROJECT_NAME=AI-Based Stock Forecasting API
VERSION=1.0.0
DESCRIPTION=Comprehensive AI-powered stock forecasting system

# Server Settings
HOST=0.0.0.0
PORT=8000
RELOAD=true

# CORS Settings
ALLOWED_HOSTS=["http://localhost:3000", "http://localhost:8080"]

# Database Settings
DATABASE_URL=postgresql://user:password@localhost:5432/ai_forecasting
REDIS_URL=redis://localhost:6379/0

# Postgres (compose interpolates these; POSTGRES_PORT frees 5432 if taken)
POSTGRES_DB=ai_forecasting
POSTGRES_USER=user
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# Trading bot (PRD) ----------------------------------------------------------
# Model registry consumed by the signal endpoint
MODEL_REGISTRY_PATH=models/registry
# Signal API base URL used by the Freqtrade strategy
SIGNAL_API_URL=http://localhost:8000
# Liveness monitoring ping URL (healthchecks.io check) — R14
HEALTHCHECKS_URL=
# Telegram remote control / alerts (Freqtrade) — R12. Create the bot with
# @BotFather; NEVER commit the real token.
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
# Dashboard (frontend) endpoints
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_FREQTRADE_URL=http://localhost:8080
NEXT_PUBLIC_FREQTRADE_USER=
NEXT_PUBLIC_FREQTRADE_PASS=
# Backups (scripts/backup_db.sh) — R17
BACKUP_DIR=backups
KEEP_DAYS=14
DATABASE_URL_PSQL=postgresql://user:change-me@localhost:5432/ai_forecasting

# Authentication Settings
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Model Settings
MODEL_STORAGE_PATH=./models
MODEL_CACHE_SIZE=10

# Data Settings
DATA_STORAGE_PATH=./data
MAX_FILE_SIZE=104857600

# Forecasting Settings
DEFAULT_FORECAST_HORIZON=7
MAX_FORECAST_HORIZON=90
MIN_HISTORICAL_DATA_DAYS=252

# Data Sources
YAHOO_FINANCE_ENABLED=true
ALPHA_VANTAGE_ENABLED=false
ALPHA_VANTAGE_API_KEY=

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=json

# Monitoring Settings
SENTRY_DSN=
PROMETHEUS_ENABLED=true

# Background Tasks
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Google Sheets Integration
GOOGLE_SHEETS_CREDENTIALS_FILE=
GOOGLE_SHEETS_SCOPES=["https://www.googleapis.com/auth/spreadsheets", "https://www.googleapis.com/auth/drive"] 